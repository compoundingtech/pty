#!/usr/bin/env node
// Thin shim that execs node against demos/loggy/main.ts with
// --experimental-strip-types so it runs directly from source without a
// separate build step. Matches the "run a demo from source" pattern used
// by ./demos/run.

import { existsSync } from 'node:fs';
import { spawnSync } from 'node:child_process';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';

const __dirname = dirname(fileURLToPath(import.meta.url));
const mainTs = join(__dirname, '..', 'demos', 'loggy', 'main.ts');

if (!existsSync(mainTs)) {
  console.error(`loggy: missing ${mainTs}`);
  process.exit(1);
}

const result = spawnSync(
  process.execPath,
  ['--experimental-strip-types', '--no-warnings', mainTs, ...process.argv.slice(2)],
  { stdio: 'inherit', env: process.env },
);

process.exit(result.status ?? 1);
