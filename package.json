{
  "name": "@myobie/pty",
  "version": "0.1.0",
  "description": "Persistent terminal sessions with detach/attach support",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/myobie/pty.git"
  },
  "keywords": [
    "terminal",
    "pty",
    "session",
    "detach",
    "attach",
    "testing",
    "tui"
  ],
  "files": [
    "bin/",
    "src/",
    "completions/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "pty": "./bin/pty"
  },
  "exports": {
    "./testing": "./src/testing/index.ts",
    "./tui": "./src/tui/index.ts"
  },
  "scripts": {
    "prepare": "git config core.hooksPath githooks 2>/dev/null || true; chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true; sh scripts/update-nix-hash.sh 2>/dev/null || true",
    "install-completions": "sh scripts/install-completions.sh",
    "typecheck": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify-docs": "node scripts/verify-docs.ts"
  },
  "dependencies": {
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.0.0"
  },
  "peerDependencies": {
    "@preact/signals-core": "^1.14.0"
  },
  "peerDependenciesMeta": {
    "@preact/signals-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@preact/signals-core": "^1.14.0",
    "@types/node": "^25.3.5",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
